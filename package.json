{
  "name": "stremio-presence",
  "version": "1.0.0",
  "description": "Real-time Discord Rich Presence for Stremio 5 — shows what you're watching with exact position, instant pause/stop, quality, and a rich idle state. Zero login.",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "stremio-presence": "src/index.js"
  },
  "scripts": {
    "start": "node src/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "stremio",
    "discord",
    "rich-presence",
    "discord-rpc",
    "presence",
    "webview2",
    "cdp",
    "mpv"
  ],
  "author": "codeptor",
  "license": "MIT",
  "homepage": "https://github.com/codeptor/stremio-presence#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codeptor/stremio-presence.git"
  },
  "bugs": {
    "url": "https://github.com/codeptor/stremio-presence/issues"
  },
  "dependencies": {
    "@xhayper/discord-rpc": "^1.3.4",
    "systray2": "^2.1.4",
    "ws": "^8.21.0"
  }
}
